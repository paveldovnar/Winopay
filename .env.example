# WinoPay Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Telegram Bot (for APK publishing)
# Get from @BotFather: https://t.me/BotFather
TG_BOT_TOKEN=123456789:ABCDEF1234567890-abcdefghijklmnopqrs

# Telegram Channel ID
# Public channel: @channel_name
# Private channel: numeric ID (e.g., -1001234567890)
TG_CHAT_ID=@winopay_builds

# Reown (WalletConnect v2) Project ID
# Get from: https://cloud.reown.com
REOWN_PROJECT_ID=your_project_id_here

# Release Signing (optional - for local release builds)
# WINOPAY_KEYSTORE_FILE=/path/to/keystore.jks
# WINOPAY_KEYSTORE_PASSWORD=your_keystore_password
# WINOPAY_KEY_ALIAS=your_key_alias
# WINOPAY_KEY_PASSWORD=your_key_password

# Solana RPC (optional - override defaults)
# SOLANA_RPC_URL_MAINNET=https://api.mainnet-beta.solana.com

# Update Endpoint (optional - for in-app updates in debug builds)
# UPDATE_ENDPOINT=https://your-server.com/latest.json
