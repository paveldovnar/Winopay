<?xml version="1.0" encoding="utf-8"?>
<!--
    Android Auto Backup rules for Android 11 and below.

    INCLUDED:
    - merchant_profile.preferences_pb: MerchantProfileStore DataStore (business name, logo path)
    - wino_pay_prefs.preferences_pb: DataStoreManager (wallet session, settings)
    - profile_logos/: Logo images copied to internal storage
    - app_database: Room database with invoices

    EXCLUDED:
    - Cache files (rebuilt on demand)
    - No-backup files
-->
<full-backup-content>
    <!-- Include DataStore files -->
    <include domain="file" path="datastore/merchant_profile.preferences_pb" />
    <include domain="file" path="datastore/wino_pay_prefs.preferences_pb" />

    <!-- Include logo images -->
    <include domain="file" path="profile_logos" />

    <!-- Include Room database -->
    <include domain="database" path="app_database" />

    <!-- Exclude cache -->
    <exclude domain="cache" path="." />
</full-backup-content>
